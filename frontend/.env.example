# Optional: override the API base URL used by the frontend.
# Leave unset in production on Vercel to use the /api proxy defined in vercel.json.
# VITE_API_BASE_URL=https://iles-1.onrender.com/api

# Local dev only: where Vite proxies /api requests (default: http://127.0.0.1:8000).
# VITE_DEV_API_PROXY=http://127.0.0.1:8000
