DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-production-secret-key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver,.onrender.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,https://iles-sepia.vercel.app,https://iles-d4ub.vercel.app
DJANGO_CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$
DJANGO_CSRF_TRUSTED_ORIGINS=https://iles-beta.vercel.app/,https://iles-1.onrender.com
DJANGO_TIME_ZONE=Africa/Nairobi
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0

NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
DATABASE_CONN_MAX_AGE=60
